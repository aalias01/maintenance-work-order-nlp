**/*_local/
data/*.csv
data/*.jsonl
data/*.json
__pycache__/
*.pyc
*.egg-info/
# OpenAI API key — NEVER commit (inline comments don't work in .gitignore!)
.env
.venv/
.ipynb_checkpoints/
# Keep small model artifacts. The full DistilBERT fine-tune (257 MB) stays
# local — GitHub rejects files >100 MB, and shipping the 2.9 MB LoRA adapter
# instead IS the point of the PEFT comparison. Reproduce the full model with
# scripts/run_local_pipeline.py.
models/*
!models/.gitkeep
!models/tfidf_pipeline.joblib
!models/lora_adapter/
!models/embeddings_index.npy
!models/embeddings_texts.json
# int8 ONNX artifacts served in production (built by scripts/build_onnx.py, each < 100 MB)
!models/onnx/
# Track everything under models/onnx/ EXCEPT the fp32 export + its external-data blob
# (~256 MB, over GitHub's 100 MB limit). Only model_int8.onnx + tokenizer files ship.
models/onnx/**/model.onnx
models/onnx/**/*.onnx.data
models/onnx/**/*.onnx_data
.DS_Store
